# Copy this file to .env for local overrides when needed.
# Vite only exposes variables prefixed with VITE_.

VITE_APP_NAME=JobSprint
# Optional remote persistence API base URL.
# If empty, repository falls back to local user-scoped storage.
VITE_JSPRINT_REMOTE_API_URL=

# Firebase (optional). If all required values are set, app uses
# Firebase Auth + Firestore persistence adapters.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
